      "id": 28,
      "category": "지리·자연",
      "text": "하와이는 매일 1cm씩 커진다 (용암 때문)."
    },
    {
      "id": 29,
      "category": "지리·자연",
      "text": "아프리카 대륙은 점점 둘로 쪼개지고 있다."
    },
    {
      "id": 30,
      "category": "지리·자연",
      "text": "몽블랑은 매년 1cm씩 높아진다."
    },
    {
      "id": 31,
      "category": "지리·자연",
      "text": "세계에서 가장 조용한 방은 마이크로소프트 본사에 있다 (-20dB)."
    },
    {
      "id": 32,
      "category": "지리·자연",
      "text": "브라질은 남미 국가 중 유일하게 포르투갈어 사용."
    },
    {
      "id": 33,
      "category": "지리·자연",
      "text": "사막의 모래는 바다로 흘러가 유리를 만든다."
    },
    {
      "id": 34,
      "category": "지리·자연",
      "text": "지구에서 가장 뜨거운 곳은 이란의 다슈테 루트 (70.7°C)."
    },
    {
      "id": 35,
      "category": "지리·자연",
      "text": "뉴질랜드에는 교통신호등보다 양이 많다."
    },
    {
      "id": 36,
      "category": "지리·자연",
      "text": "세계에서 가장 큰 살아있는 생물은 미국 오레곤의 버섯 군락 (면적 9.6㎢)."
    },
    {
      "id": 37,
      "category": "지리·자연",
      "text": "일본에는 사각형 수박이 있다 (선물용)."
    },
    {
      "id": 38,
      "category": "지리·자연",
      "text": "베네치아는 매년 2mm씩 가라앉는다."
    },
    {
      "id": 39,
      "category": "지리·자연",
      "text": "호주의 울룰루(에어즈록)은 지하로도 이어져 있다."
    },
    {
      "id": 40,
      "category": "지리·자연",
      "text": "세계에서 가장 긴 강은 아마존이 아니라 나일강 (논란 중)."
    },
    {
      "id": 41,
      "category": "과학·기술",
      "text": "다이아몬드는 석탄으로 만들어지지 않는다 (대부분 맨틀에서)."
    },
    {
      "id": 42,
      "category": "과학·기술",
      "text": "우주에서는 냄새를 맡을 수 없다 (진공)."
    },
    {
      "id": 43,
      "category": "과학·기술",
      "text": "번개는 태양 표면보다 5배 뜨겁다."
    },
    {
      "id": 44,
      "category": "과학·기술",
      "text": "GPS는 상대성 이론 없이는 작동 안 된다."
    },
    {
      "id": 45,
      "category": "과학·기술",
      "text": "플라스틱은 최소 400년 분해된다."
    },
    {
      "id": 46,
      "category": "과학·기술",
      "text": "스마트폰 속 금은 올림픽 금메달보다 많다."
    },
    {
      "id": 47,
      "category": "과학·기술",
      "text": "냉장고는 집에서 가장 전기 많이 먹는 가전."
    },
    {
      "id": 48,
      "category": "과학·기술",
      "text": "우주선은 지구 대기권 밖에서도 소리를 낸다 (진동으로)."
    },
    {
      "id": 49,
      "category": "과학·기술",
      "text": "비행기는 뒤로 날 수도 있다 (엔진 역추진)."
    },
    {
      "id": 50,
      "category": "과학·기술",
      "text": "Wi-Fi라는 이름은 아무 의미 없다 (Wireless Fidelity 아님)."
    },
    {
      "id": 51,
      "category": "과학·기술",
      "text": "세계 최초의 컴퓨터 버그는 진짜 나방이었다 (1947)."
    },
    {
      "id": 52,
      "category": "과학·기술",
      "text": "1초는 세슘 원자의 9,192,631,770번 진동."
    },
    {
      "id": 53,
      "category": "과학·기술",
      "text": "물은 110도에서도 얼 수 있다 (초임계 상태)."
    },
    {
      "id": 54,
      "category": "과학·기술",
      "text": "태양은 녹색이지만 대기 때문에 노란색으로 보인다."
    },
    {
      "id": 55,
      "category": "과학·기술",
      "text": "달은 지구에서 매년 3.8cm씩 멀어진다."
    },
    {
      "id": 56,
      "category": "과학·기술",
      "text": "우주복은 한 벌에 1,500만 달러."
    },
    {
      "id": 57,
      "category": "과학·기술",
      "text": "QR코드는 일본 자동차 부품 추적용으로 시작."
    },
    {
      "id": 58,
      "category": "과학·기술",
      "text": "비행기 창문 구멍은 압력 조절용."
    },
    {
      "id": 59,
      "category": "과학·기술",
      "text": "세계 최초의 사진은 8시간 노출 (1826)."
    },
    {
      "id": 60,
      "category": "과학·기술",
      "text": "인공지능은 고양이 사진으로 학습 시작 (Google, 2012)."
    },
    {
      "id": 61,
      "category": "문화·역사",
      "text": "피자는 원래 가난한 사람 음식이었다."
    },
    {
      "id": 62,
      "category": "문화·역사",
      "text": "세계에서 가장 많이 팔린 책은 성경이 아니라 ‘인용구 사전’."
    },
    {
      "id": 63,
      "category": "문화·역사",
      "text": "옥토버페스트는 9월에 시작한다."
    },
    {
      "id": 64,
      "category": "문화·역사",
      "text": "스페인 국가는 가사가 없다."
    },
    {
      "id": 65,
      "category": "문화·역사",
      "text": "프랑스에서는 집에서 돼지 이름 ‘나폴레옹’ 금지."
    },
    {
      "id": 66,
      "category": "문화·역사",
      "text": "일본에는 ‘카페에서 고양이와 놀기’ 카페가 있다."
    },
    {
      "id": 67,
      "category": "문화·역사",
      "text": "세계 최초의 소설은 일본의 겐지모노가타리 (11세기)."
    },
    {
      "id": 68,
      "category": "문화·역사",
      "text": "중국 만리장성은 우주에서 안 보인다."
    },
    {
      "id": 69,
      "category": "문화·역사",
      "text": "클레오파트라는 피라미드보다 에펠탑에 더 가까이 살았다."
    },
    {
      "id": 70,
      "category": "문화·역사",
      "text": "빅벤은 시계가 아니라 종 이름."
    },
    {
      "id": 71,
      "category": "문화·역사",
      "text": "하와이 피자는 캐나다에서 발명."
    },
    {
      "id": 72,
      "category": "문화·역사",
      "text": "세계에서 가장 오래된 깃발은 덴마크 국기 (1219년~)."
    },
    {
      "id": 73,
      "category": "문화·역사",
      "text": "모나리자는 눈썹이 없다 (당시 유행)."
    },
    {
      "id": 74,
      "category": "문화·역사",
      "text": "세계 최초의 대학은 모로코에 있다 (859년)."
    },
    {
      "id": 75,
      "category": "문화·역사",
      "text": "일본에서는 크리스마스에 KFC 먹는다."
    },
    {
      "id": 76,
      "category": "문화·역사",
      "text": "김치는 유네스코 무형유산."
    },
    {
      "id": 77,
      "category": "문화·역사",
      "text": "세계에서 가장 많이 쓰는 비밀번호는 123456."
    },
    {
      "id": 78,
      "category": "문화·역사",
      "text": "‘OK’는 ‘oll korrect’(all correct 오타)에서 왔다."
    },
    {
      "id": 79,
      "category": "문화·역사",
      "text": "세계에서 가장 짧은 노래는 1.3초 (영국 밴드 Napalm Death)."
    },
    {
      "id": 80,
      "category": "문화·역사",
      "text": "셰익스피어는 ‘눈 깜빡할 사이’ 표현 창시."
    },
    {
      "id": 81,
      "category": "기타 재미",
      "text": "펭귄은 무릎이 있다 (털 속에 숨겨짐)."
    },
    {
      "id": 82,
      "category": "기타 재미",
      "text": "바나나는 열매, 딸기는 채소 (식물학 기준)."
    },
    {
      "id": 83,
      "category": "기타 재미",
      "text": "세계에서 가장 많이 훔친 책은 성경."
    },
    {
      "id": 84,
      "category": "기타 재미",
      "text": "꿀은 영원히 상하지 않는다 (고고학 발굴 꿀도 먹을 수 있음)."
    },
    {
      "id": 85,
      "category": "기타 재미",
      "text": "코끼리는 점프 못 한다."
    },
    {
      "id": 86,
      "category": "기타 재미",
      "text": "세계에서 가장 비싼 커피는 코끼리 똥 커피 (코피 루왁은 2위)."
    },
    {
      "id": 87,
      "category": "기타 재미",
      "text": "우체국은 세계에서 가장 큰 고용주 (국가별 합산)."
    },
    {
      "id": 88,
      "category": "기타 재미",
      "text": "‘스팸’ 메일은 몬티 파이선 스킴에서 유래."
    },
    {
      "id": 89,
      "category": "기타 재미",
      "text": "세계에서 가장 긴 영화는 85시간 (스웨덴 실험영화)."
    },
    {
      "id": 90,
      "category": "기타 재미",
      "text": "개는 인간의 감정을 냄새로 안다."
    },
    {
      "id": 91,
      "category": "기타 재미",
      "text": "일본 지하철에는 ‘밀어주는 직원’이 있다."
    },
    {
      "id": 92,
      "category": "기타 재미",
      "text": "세계에서 가장 작은 공원은 직경 60cm (미국 오리건)."
    },
    {
      "id": 93,
      "category": "기타 재미",
      "text": "‘헬로’는 전화 발명 후 처음 나온 인사."
    },
    {
      "id": 94,
      "category": "기타 재미",
      "text": "라면은 일본에서 중국 요리로 시작."
    },
    {
      "id": 95,
      "category": "기타 재미",
      "text": "세계에서 가장 많이 방문한 웹사이트는 구글이 아니라 페이스북 (일부 연도)."
    },
    {
      "id": 96,
      "category": "기타 재미",
      "text": "고양이는 낙하산 없이 20층에서도 생존 (기록 있음)."
    },
    {
      "id": 97,
      "category": "기타 재미",
      "text": "‘월급’은 소금(salary)에서 왔다 (로마 병사 보상)."
    },
    {
      "id": 98,
      "category": "기타 재미",
      "text": "세계에서 가장 오래된 나무는 스웨덴의 9,550살 전나무."
    },
    {
      "id": 99,
      "category": "기타 재미",
      "text": "잠자리는 하루만 산다는 건 오해 (성충은 몇 주)."
    },
    {
      "id": 100,
      "category": "기타 재미",
      "text": "(끝)"
    }
  ],
  "명언": [
    {"id":1,"category":"일반","quote":"인생은 가까이서 보면 비극, 멀리서 보면 희극이다.","author":"찰리 채플린"},
    {"id":2,"category":"일반","quote":"가장 훌륭한 복수는 성공이다.","author":"프랭크 시나트라"},
    {"id":3,"category":"일반","quote":"오늘 할 수 있는 일을 내일로 미루지 마라.","author":"벤저민 프랭클린"},
    {"id":4,"category":"일반","quote":"실패는 성공의 어머니다.","author":"토마스 에디슨"},
    {"id":5,"category":"일반","quote":"내일 죽을 것처럼 살아라. 영원히 살 것처럼 배워라.","author":"간디"},
    {"id":6,"category":"일반","quote":"가장 어두운 밤이 지나면 가장 밝은 별이 보인다.","author":"토마스 풀러"},
    {"id":7,"category":"일반","quote":"자신을 믿는 자만이 남을 믿을 수 있다.","author":"요한 볼프강 폰 괴테"},
    {"id":8,"category":"일반","quote":"기회는 준비된 자에게만 온다.","author":"루이 파스퇴르"},
    {"id":9,"category":"일반","quote":"행복은 목적지가 아니라 여정이다.","author":"마거릿 리 런벡"},
    {"id":10,"category":"일반","quote":"당신이 할 수 있다고 믿든, 못한다고 믿든, 당신의 믿음이 맞다.","author":"헨리 포드"},
    {"id":11,"category":"일반","quote":"가장 큰 위험은 위험을 감수하지 않는 것이다.","author":"마크 저커버그"},
    {"id":12,"category":"일반","quote":"실패해도 괜찮다. 다시 시작하면 된다.","author":"월트 디즈니"},
    {"id":13,"category":"일반","quote":"시간은 금이다, 그러나 금으로 시간을 살 수 없다.","author":"탈무드"},
    {"id":14,"category":"일반","quote":"가장 중요한 것은 멈추지 않는 것이다.","author":"스티브 잡스"},
    {"id":15,"category":"일반","quote":"작은 구멍이 배를 침몰시킨다.","author":"벤저민 프랭클린"},
    {"id":16,"category":"일반","quote":"오늘 심은 씨앗이 내일의 숲이 된다.","author":"중국 속담"},
    {"id":17,"category":"일반","quote":"자신을 이기는 것이 가장 큰 승리다.","author":"플라톤"},
    {"id":18,"category":"일반","quote":"용기는 두려움이 없는 게 아니라, 두려움에 맞서는 것이다.","author":"넬슨 만델라"},
    {"id":19,"category":"일반","quote":"꿈을 적어 두지 않으면, 그것은 단지 소망일 뿐이다.","author":"앙투안 드 생텍쥐페리"},
    {"id":20,"category":"일반","quote":"인생은 자전거 타기와 같다. 균형을 유지하려면 계속 움직여야 한다.","author":"알베르트 아인슈타인"},
    {"id":21,"category":"일반","quote":"실패는 선택이 아니다. 포기는 선택이다.","author":"윈스턴 처칠"},
    {"id":22,"category":"일반","quote":"가장 큰 영광은 넘어지지 않는 것이 아니라, 넘어질 때마다 일어서는 것이다.","author":"공자"},
    {"id":23,"category":"일반","quote":"당신의 시간은 제한되어 있다. 남의 인생을 살지 마라.","author":"스티브 잡스"},
    {"id":24,"category":"일반","quote":"가장 어려운 일은 시작하는 것이다. 나머지는 그저 꾸준함이다.","author":"아멜리아 에어하트"},
    {"id":25,"category":"일반","quote":"성공은 최종 목적이 아니다. 실패도 치명적이지 않다. 중요한 것은 계속 나아가는 용기다.","author":"윈스턴 처칠"},

    {"id":26,"category":"사랑·인간관계","quote":"사랑은 서로 마주 보는 것이 아니라, 같은 방향을 바라보는 것이다.","author":"생텍쥐페리"},
    {"id":27,"category":"사랑·인간관계","quote":"진정한 친구는 당신이 잊을 때도 당신을 기억한다.","author":"윈스턴 처칠"},
    {"id":28,"category":"사랑·인간관계","quote":"사랑은 말로 하지 않는다. 행동으로 한다.","author":"어머니 테레사"},
    {"id":29,"category":"사랑·인간관계","quote":"용서는 사랑의 시작이다.","author":"브라이언트 맥길"},
    {"id":30,"category":"사랑·인간관계","quote":"친구는 선택한 가족이다.","author":"아리스토텔레스"},
    {"id":31,"category":"사랑·인간관계","quote":"사랑은 조건이 없다. 조건이 있다면 그건 사랑이 아니다.","author":"오쇼"},
    {"id":32,"category":"사랑·인간관계","quote":"진정한 사랑은 서로를 자유롭게 하는 것이다.","author":"칼릴 지브란"},
    {"id":33,"category":"사랑·인간관계","quote":"사람은 사랑하기 위해 태어났다.","author":"레프 톨스토이"},
    {"id":34,"category":"사랑·인간관계","quote":"친절은 언어가 아니라 행동이다.","author":"랜들리"},
    {"id":35,"category":"사랑·인간관계","quote":"사랑은 눈이 아니라 마음으로 본다.","author":"윌리엄 셰익스피어"},
    {"id":36,"category":"사랑·인간관계","quote":"진정한 사랑은 영원히 변하지 않는다.","author":"성경 (고린도전서 13:8)"},
    {"id":37,"category":"사랑·인간관계","quote":"친구는 당신의 결점을 말해 주는 사람이다.","author":"아리스토텔레스"},
    {"id":38,"category":"사랑·인간관계","quote":"사랑은 서로를 완성하는 것이 아니라, 서로를 있는 그대로 받아들이는 것이다.","author":"레오 부스카글리아"},
    {"id":39,"category":"사랑·인간관계","quote":"진정한 우정은 시간이 아닌 마음으로 측정된다.","author":"조지 엘리엇"},
    {"id":40,"category":"사랑·인간관계","quote":"사랑은 조건이 아니라 선택이다.","author":"스콧 애덤스"},
    {"id":41,"category":"사랑·인간관계","quote":"진정한 사랑은 서로의 자유를 존중한다.","author":"칼릴 지브란"},
    {"id":42,"category":"사랑·인간관계","quote":"친구는 당신이 실패했을 때도 곁에 있는 사람이다.","author":"월터 윈첼"},
    {"id":43,"category":"사랑·인간관계","quote":"사랑은 말보다 행동으로 증명된다.","author":"윌리엄 셰익스피어"},
    {"id":44,"category":"사랑·인간관계","quote":"진정한 우정은 비밀을 공유하는 것이다.","author":"엘버트 허버드"},
    {"id":45,"category":"사랑·인간관계","quote":"사랑은 서로를 빛나게 한다.","author":"수잔 폴리 개럿"},

    {"id":46,"category":"지혜·철학","quote":"너 자신을 알라.","author":"소크라테스"},
    {"id":47,"category":"지혜·철학","quote":"생각이 행동이 되고, 행동이 습관이 되고, 습관이 운명이 된다.","author":"라오쯔"},
    {"id":48,"category":"지혜·철학","quote":"지식은 힘이다.","author":"프랜시스 베이컨"},
    {"id":49,"category":"지혜·철학","quote":"가장 현명한 사람은 스스로를 아는 사람이다.","author":"탈무드"},
    {"id":50,"category":"지혜·철학","quote":"시간은 모든 상처를 치유한다.","author":"메난드로스"},
    {"id":51,"category":"지혜·철학","quote":"진리는 단순하다.","author":"레오나르도 다빈치"},
    {"id":52,"category":"지혜·철학","quote":"인간은 생각하는 갈대다.","author":"블레즈 파스칼"},
    {"id":53,"category":"지혜·철학","quote":"자유는 책임과 함께 온다.","author":"엘리너 루스벨트"},
    {"id":54,"category":"지혜·철학","quote":"변화는 유일한 영원한 것이다.","author":"헤라클레이토스"},
