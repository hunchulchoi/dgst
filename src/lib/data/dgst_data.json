    {"id":74,"category":"도전·용기","quote":"용기는 두려움이 없는 것이 아니라, 두려움에 맞서는 것이다.","author":"마크 트웨인"},
    {"id":75,"category":"도전·용기","quote":"실패는 성공으로 가는 디딤돌이다.","author":"메리 케이 애쉬"},
    {"id":76,"category":"도전·용기","quote":"가장 큰 위험은 위험을 감수하지 않는 것이다.","author":"존 F. 케네디"},
    {"id":77,"category":"도전·용기","quote":"포기하지 않는 한, 실패는 없다.","author":"마이클 조던"},
    {"id":78,"category":"도전·용기","quote":"용기는 작은 선택의 연속이다.","author":"메리 앤 래드마허"},
    {"id":79,"category":"도전·용기","quote":"실패는 선택이 아니다. 포기는 선택이다.","author":"아놀드 슈워제네거"},
    {"id":80,"category":"도전·용기","quote":"가장 큰 영광은 넘어지지 않는 것이 아니라, 넘어질 때마다 일어서는 것이다.","author":"넬슨 만델라"},
    {"id":81,"category":"도전·용기","quote":"용기는 전진하는 것이다. 두려움 속에서도.","author":"마틴 루터 킹 주니어"},
    {"id":82,"category":"도전·용기","quote":"실패는 성공의 일부다.","author":"아리안나 허핑턴"},
    {"id":83,"category":"도전·용기","quote":"가장 큰 위험은 아무것도 하지 않는 것이다.","author":"피터 드러커"},
