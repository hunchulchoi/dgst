NODE_ENV="development"


# Auth.js secret
AUTH_SECRET=""

# jwt secret
NEXTAUTH_SECRET=""

# Google client OAuth credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# kakao  client OAuth credentials
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

#database credentials
MONGODB_CONNECTION_STRING=""
DB_NAME=""

# Google reCaptcha credentials
PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY=""
GOOGLE_RECAPTCHA_SECRET_KEY=""

# file-upload
UPLOAD_PATH=""

# redis — 컨테이너명 dgst_redis, DNS(compose)는 서비스명 redis
# 운영·개발 Docker 앱: redis://redis:6379 또는 redis://dgst_redis:6379 (코드에서 redis/127.0.0.1로 보정)
REDIS_URL="redis://redis:6379"
REDIS_PREFIX="dgst:"