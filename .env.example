NODE_ENV="development"


# Auth.js secret
AUTH_SECRET=""

# jwt secret
NEXTAUTH_SECRET=""

# Google client OAuth credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# kakao  client OAuth credentials
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# PostgreSQL (primary database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/dgstdb"
POSTGRES_PASSWORD=""

# Legacy MongoDB — migration scripts only (db:migrate-data, db:verify-migration)
# MONGODB_CONNECTION_STRING=""
# DB_NAME=""
MONGO_INITDB_ROOT_PASSWORD=""

# Google reCaptcha credentials
PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY=""
GOOGLE_RECAPTCHA_SECRET_KEY=""

# file-upload
UPLOAD_PATH=""

# logging (Grafana/Loki — stdout JSON 한 줄)
LOG_LEVEL="info"
LOG_FORMAT="json"
SERVICE_NAME="dgst"
LOG_DIR="./logs"

# Legacy Redis — migration scripts only (db:migrate-data, db:verify-migration)
# REDIS_URL="redis://localhost:6379"
# REDIS_PREFIX="dgst"
