server {
    listen 80;
    server_name dgst.me;
    return 301 https://www.dgst.me$request_uri;
}

server {
    listen 80;
    server_name www.dgst.me;
    return 301 https://www.dgst.me$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name dgst.me;

    # 필요하면 여기에 인증서/키 추가:
    # ssl_certificate /mnt/dgst/conf/private/2024/www_dgst.site_cert-2.pem;
    # ssl_certificate_key /mnt/dgst/conf/private/2024/www_dgst.site-2.pem;

    ssl_client_certificate /mnt/dgst/conf/private/2025/dgst_me_authenticated_origin_pull_ca.pem;
    ssl_verficate_client on;

    return 301 https://www.dgst.me$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name www.dgst.me;

    # 필요하면 인증서/키 추가
    # ssl_certificate /mnt/dgst/conf/private/2024/www_dgst.site_cert-2.pem;
    # ssl_certificate_key /mnt/dgst/conf/private/2024/www_dgst.site-2.pem;

    ssl_client_certificate /mnt/dgst/conf/private/2025/dgst_me_authenticated_origin_pull_ca.pem;
    ssl_verficate_client on;

    location / {
        proxy_pass_header Server;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # websocket (필요 시)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $http_connection;

        proxy_pass http://127.0.0.1:3000;
        proxy_redirect off;
        proxy_http_version 1.1;

        proxy_buffers 32 16k;
        proxy_busy_buffers_size 64k;
        proxy_cache off;

        add_header 'Cache-Control' 'no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0';

        # 404, 502 에러 시 /board/free로 리다이렉트
        error_page 404 = @fallback;
        error_page 502 = @fallback;
    }

    location @fallback {
        return 302 /board/free;
    }

    # 이미지 디렉토리: location과 alias에 슬래시 일치
    location /images/ {
        alias /mnt/dgst/volume/uploads/;
        valid_referers none blocked server_names *.dgst.me dgst.me;
        if ($invalid_referer) {
            return 302 /images/dgst.png;
        }

        log_not_found off;
        access_log off;
        expires 1w;
        try_files $uri $uri/ =404;
    }

    # 정확한 매칭(대체 이미지)
    location = /images/dgst.png {
        alias /mnt/dgst/volume/uploads/jjal/dgst.png;
    }
}
