server {
    listen 80;
    server_name dgst.site;
    return 301 https://www.dgst.site$request_uri;
}

server {
    listen 80;
    server_name www.dgst.site;
    return 301 https://www.dgst.site$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name dgst.site;

    ssl_certificate /mnt/dgst/conf/private/2024/www_dgst.site_cert-2.pem;
    ssl_certificate_key /mnt/dgst/conf/private/2024/www_dgst.site-2.pem;

    return 301 https://www.dgst.site$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name www.dgst.site;

    ssl_certificate /mnt/dgst/conf/private/2024/www_dgst.site_cert-2.pem;
    ssl_certificate_key /mnt/dgst/conf/private/2024/www_dgst.site-2.pem;

    # 권장 TLS 강화(선택)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass_header Server;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # websocket 지원 필요하면 추가
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $http_connection;

        proxy_pass http://127.0.0.1:3000;
        proxy_redirect off;
        proxy_http_version 1.1;

        proxy_buffers 32 16k;
        proxy_busy_buffers_size 64k;
        proxy_cache off;

        add_header 'Cache-Control' 'no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0';
    }

    # 이미지 파일만 캐시 적용
    location ~* \.(jpg|jpeg|png|gif|webp)$ {
        alias /mnt/dgst/volume/uploads/;
        valid_referers none blocked server_names *.dgst.site dgst.site;
        if ($invalid_referer) {
            return 302 /images/dgst.png;
        }

        log_not_found off;
        access_log off;
        expires 1w;
        try_files $uri $uri/ =404;
    }

    # 비디오 파일은 캐시 안함
    location ~* \.(mp4|mov|avi|webm)$ {
        alias /mnt/dgst/volume/uploads/;
        valid_referers none blocked server_names *.dgst.site dgst.site;
        if ($invalid_referer) {
            return 302 /images/dgst.png;
        }

        log_not_found off;
        access_log off;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        try_files $uri $uri/ =404;
    }

    # 핫링크용 대체 이미지(정확히 매칭)
    location = /images/dgst.png {
        alias /mnt/dgst/volume/uploads/jjal/dgst.png;
    }
}
